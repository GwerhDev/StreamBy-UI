{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "tsBuildInfoFile": "./node_modules/.tsbuildinfo",
    "lib": ["DOM", "DOM.Iterable", "ESNext"],
    "allowJs": true
  },
  "include": ["src"],
  "exclude": ["node_modules", "src/**/*.test.ts", "src/**/*.test.tsx", "src/**/*.spec.ts", "src/**/*.spec.tsx", "src/test"]
}
